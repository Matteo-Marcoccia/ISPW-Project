<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: linear-gradient(to bottom right, #6200EE, #E61C5D);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.questtable.view.controller.PagamentoController">
    <children>
        <HBox alignment="CENTER_LEFT" layoutX="30.0" layoutY="20.0" prefHeight="45.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="20.0">
            <children>
                <Button mnemonicParsing="false" onAction="#onTornaDettaglioClick" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="&lt; Torna al Dettaglio">
                    <font>
                        <Font name="Segoe UI Bold" size="13.0" />
                    </font>
                </Button>
            </children>
        </HBox>

        <VBox alignment="CENTER" spacing="18.0" AnchorPane.bottomAnchor="28.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="64.0">
            <children>
                <VBox alignment="CENTER" spacing="6.0">
                    <children>
                        <Label text="Pagamento" textFill="WHITE">
                            <font>
                                <Font name="Segoe UI Bold" size="30.0" />
                            </font>
                        </Label>
                        <Label text="Controlla il riepilogo e simula il pagamento" textFill="#EAEAEA">
                            <font>
                                <Font name="Segoe UI" size="13.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox alignment="TOP_CENTER" maxWidth="430.0" prefWidth="430.0" spacing="18.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 10, 0, 0, 4);">
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                    </padding>
                    <children>
                        <VBox prefHeight="170.0" spacing="7.0" style="-fx-background-color: #F7F5FC; -fx-background-radius: 12;">
                            <padding>
                                <Insets bottom="14.0" left="16.0" right="16.0" top="14.0" />
                            </padding>
                            <children>
                                <Label text="Riepilogo preventivo" textFill="#6200EE">
                                    <font>
                                        <Font name="Segoe UI Bold" size="14.0" />
                                    </font>
                                </Label>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Gioco" textFill="#666666" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblGioco" text="-" textFill="#1A1A1A">
                                            <font>
                                                <Font name="Segoe UI Bold" size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Quando" textFill="#666666" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblQuando" text="-" textFill="#1A1A1A">
                                            <font>
                                                <Font name="Segoe UI Bold" size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Partecipanti" textFill="#666666" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblPartecipanti" text="-" textFill="#1A1A1A">
                                            <font>
                                                <Font name="Segoe UI Bold" size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Punti previsti" textFill="#4CAF50" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblPunti" text="+0 punti" textFill="#4CAF50">
                                            <font>
                                                <Font name="Segoe UI Bold" size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Totale" textFill="#1A1A1A">
                                            <font>
                                                <Font name="Segoe UI Bold" size="15.0" />
                                            </font>
                                        </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblTotale" text="-" textFill="#6200EE">
                                            <font>
                                                <Font name="Segoe UI Bold" size="17.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER_LEFT" spacing="7.0">
                            <children>
                                <Label text="Metodo pagamento" textFill="#1A1A1A">
                                    <font>
                                        <Font name="Segoe UI Bold" size="13.0" />
                                    </font>
                                </Label>
                                <ComboBox fx:id="cmbMetodoPagamento" maxWidth="Infinity" prefHeight="36.0" style="-fx-background-color: #F4F4F6; -fx-background-radius: 6;" />
                                <Label fx:id="lblMessaggioPagamento" textFill="#E61C5D">
                                    <font>
                                        <Font name="Segoe UI Bold" size="12.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onPagaClick" prefHeight="38.0" style="-fx-background-color: #6200EE; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Paga">
                            <font>
                                <Font name="Segoe UI Bold" size="12.5" />
                            </font>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
