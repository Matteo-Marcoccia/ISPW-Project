<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: linear-gradient(to bottom right, #6200EE, #E61C5D);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.questtable.view.controller.RichiestaPrenotazioneOkController">
    <children>
        <VBox alignment="CENTER" spacing="15.0" AnchorPane.bottomAnchor="26.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="28.0">
            <children>
                <StackPane alignment="CENTER" prefHeight="64.0" prefWidth="64.0">
                    <children>
                        <Circle fill="#12C970" radius="32.0" />
                        <Label text="OK" textFill="WHITE">
                            <font>
                                <Font name="Segoe UI Bold" size="18.0" />
                            </font>
                        </Label>
                    </children>
                </StackPane>

                <VBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label text="Richiesta prenotazione inviata" textFill="WHITE">
                            <font>
                                <Font name="Segoe UI Bold" size="29.0" />
                            </font>
                        </Label>
                        <Label text="Il gestore ricevera' la tua richiesta e potra' confermarla" textFill="#F0F0F0">
                            <font>
                                <Font name="Segoe UI" size="13.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox maxWidth="430.0" prefWidth="430.0" spacing="14.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 10, 0, 0, 4);">
                    <padding>
                        <Insets bottom="22.0" left="24.0" right="24.0" top="22.0" />
                    </padding>
                    <children>
                        <VBox alignment="CENTER" spacing="4.0" style="-fx-background-color: #F7F5FC; -fx-background-radius: 10;">
                            <padding>
                                <Insets bottom="13.0" left="14.0" right="14.0" top="13.0" />
                            </padding>
                            <children>
                                <Label text="Codice prenotazione" textFill="#6200EE">
                                    <font>
                                        <Font name="Segoe UI Bold" size="11.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblCodicePrenotazione" text="#QT0" textFill="#1A1A1A">
                                    <font>
                                        <Font name="Segoe UI Bold" size="18.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <Label text="Dettagli richiesta" textFill="#1A1A1A">
                            <font>
                                <Font name="Segoe UI Bold" size="14.0" />
                            </font>
                        </Label>

                        <VBox spacing="8.0">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Gioco" textFill="#666666" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblGioco" text="-" textFill="#1A1A1A">
                                            <font>
                                                <Font name="Segoe UI Bold" size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Tavolo prenotato" textFill="#666666" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblTavoloPrenotato" text="-" textFill="#1A1A1A">
                                            <font>
                                                <Font name="Segoe UI Bold" size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Data richiesta" textFill="#666666" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblDataRichiesta" text="-" textFill="#1A1A1A">
                                            <font>
                                                <Font name="Segoe UI Bold" size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Ora richiesta" textFill="#666666" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblOraRichiesta" text="-" textFill="#1A1A1A">
                                            <font>
                                                <Font name="Segoe UI Bold" size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Posti prenotati" textFill="#666666" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblPartecipanti" text="-" textFill="#1A1A1A">
                                            <font>
                                                <Font name="Segoe UI Bold" size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="3.0" style="-fx-background-color: #EAF8F0; -fx-background-radius: 10;">
                            <padding>
                                <Insets bottom="13.0" left="14.0" right="14.0" top="13.0" />
                            </padding>
                            <children>
                                <Label text="Importo pagato" textFill="#178A4F">
                                    <font>
                                        <Font name="Segoe UI Bold" size="11.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblImportoPagato" text="-" textFill="#0FA45D">
                                    <font>
                                        <Font name="Segoe UI Bold" size="21.0" />
                                    </font>
                                </Label>
                                <Label text="Pagamento completato con successo" textFill="#178A4F">
                                    <font>
                                        <Font name="Segoe UI" size="11.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox maxWidth="430.0" prefWidth="430.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10;">
                    <padding>
                        <Insets bottom="14.0" left="18.0" right="18.0" top="14.0" />
                    </padding>
                    <children>
                        <Label text="Riceverai una conferma" textFill="#1A1A1A">
                            <font>
                                <Font name="Segoe UI Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label text="Quando il gestore approvera' la richiesta, la prenotazione sara' confermata definitivamente." textFill="#666666" wrapText="true">
                            <font>
                                <Font name="Segoe UI" size="11.5" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox maxWidth="430.0" prefWidth="430.0" spacing="8.0">
                    <children>
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onTornaHomeClick" prefHeight="36.0" style="-fx-background-color: white; -fx-text-fill: #6200EE; -fx-background-radius: 8; -fx-cursor: hand;" text="Torna alla Home">
                            <font>
                                <Font name="Segoe UI Bold" size="12.0" />
                            </font>
                        </Button>
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onPrenotaAltroTavoloClick" prefHeight="36.0" style="-fx-background-color: transparent; -fx-border-color: white; -fx-border-radius: 8; -fx-text-fill: white; -fx-cursor: hand;" text="Prenota un altro tavolo">
                            <font>
                                <Font name="Segoe UI Bold" size="12.0" />
                            </font>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
