<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: linear-gradient(to bottom right, #6200EE, #E61C5D);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.questtable.view.controller.ConfermaPrenotazioniController">
    <children>
        <HBox alignment="CENTER_LEFT" layoutX="30.0" layoutY="20.0" prefHeight="45.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="20.0">
            <children>
                <Button mnemonicParsing="false" onAction="#onTornaHomeClick" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="&lt; Torna alla Home">
                    <font>
                        <Font name="Segoe UI Bold" size="13.0" />
                    </font>
                </Button>
            </children>
        </HBox>

        <VBox alignment="TOP_CENTER" spacing="16.0" AnchorPane.bottomAnchor="35.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="70.0">
            <children>
                <VBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label text="Prenotazioni in Attesa" textFill="WHITE">
                            <font>
                                <Font name="Segoe UI Bold" size="36.0" />
                            </font>
                        </Label>
                        <Label text="Conferma le richieste inviate dai clienti" textFill="WHITE">
                            <font>
                                <Font name="Segoe UI" size="14.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <Label fx:id="lblMessaggioGestore" textFill="#B8FFE0">
                    <font>
                        <Font name="Segoe UI Bold" size="13.0" />
                    </font>
                </Label>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="430.0" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="containerPrenotazioni" alignment="TOP_CENTER" spacing="16.0" style="-fx-background-color: transparent;">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</AnchorPane>
