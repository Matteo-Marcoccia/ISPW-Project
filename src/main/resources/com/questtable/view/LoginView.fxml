                            <VBox.margin>
                                <Insets bottom="10.0" />
                            </VBox.margin>
                        </SVGPath>
                        <Label text="QuestTable" textFill="WHITE">
                            <font>
                                <Font name="Segoe UI Bold" size="32.0" />
                            </font>
                        </Label>
                        <Label text="Accedi al tuo account" textFill="#EAEAEA">
                            <font>
                                <Font name="Segoe UI" size="13.0" />
                            </font>
                        </Label>
                    </children>
                    <VBox.margin>
                        <Insets bottom="5.0" />
                    </VBox.margin>
                </VBox>

                <VBox alignment="TOP_CENTER" maxWidth="350.0" prefHeight="340.0" prefWidth="350.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 10, 0, 0, 4);">
                    <children>

                        <StackPane alignment="CENTER" maxHeight="46.0" maxWidth="46.0" prefHeight="46.0" prefWidth="46.0">
                            <children>
                                <Rectangle arcHeight="14.0" arcWidth="14.0" fill="#9C27B0" height="44.0" width="44.0" />
                                <SVGPath content="M11 7L9.6 8.4l3.6 3.6H2v2h11.2l-3.6 3.6L11 21l7-7-7-7zm9-4H4c-1.1 0-2 .9-2 2v4h2V5h16v14H4v-4H2v4c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" fill="WHITE" scaleX="0.9" scaleY="0.9" />
                            </children>
                            <VBox.margin>
                                <Insets top="24.0" />
                            </VBox.margin>
                        </StackPane>

                        <Label text="Accedi" textFill="#1A1A1A">
                            <font>
                                <Font name="Segoe UI Bold" size="22.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="12.0" />
                            </VBox.margin>
                        </Label>

                        <Label text="Inserisci le tue credenziali per continuare" textFill="#777777">
                            <font>
                                <Font name="Segoe UI" size="12.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="4.0" />
                            </VBox.margin>
                        </Label>

                        <VBox alignment="CENTER_LEFT" spacing="5.0">
                            <children>
                                <Label text="Username" textFill="#1A1A1A">
                                    <font>
                                        <Font name="Segoe UI Bold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="txtUsername" promptText="matteo" prefHeight="35.0" style="-fx-background-color: #F4F4F6; -fx-background-radius: 6; -fx-text-fill: #1A1A1A; -fx-prompt-text-fill: #A0A0A0; -fx-padding: 0 10 0 10;">
                                    <font>
                                        <Font name="Segoe UI" size="12.5" />
                                    </font>
                                </TextField>
                            </children>
                            <VBox.margin>
                                <Insets left="24.0" right="24.0" top="20.0" />
                            </VBox.margin>
                        </VBox>

                        <VBox alignment="CENTER_LEFT" spacing="5.0">
                            <children>
                                <Label text="Password" textFill="#1A1A1A">
                                    <font>
                                        <Font name="Segoe UI Bold" size="12.0" />
                                    </font>
                                </Label>
                                <PasswordField fx:id="txtPassword" promptText="••••••••" prefHeight="35.0" style="-fx-background-color: #F4F4F6; -fx-background-radius: 6; -fx-text-fill: #1A1A1A; -fx-prompt-text-fill: #A0A0A0; -fx-padding: 0 10 0 10;">
                                    <font>
                                        <Font name="Segoe UI" size="12.5" />
                                    </font>
                                </PasswordField>
                            </children>
                            <VBox.margin>
                                <Insets left="24.0" right="24.0" top="15.0" />
                            </VBox.margin>
                        </VBox>

                        <Button fx:id="btnAccediInForm" mnemonicParsing="false" onAction="#onLoginSubmit" prefHeight="36.0" prefWidth="302.0" style="-fx-background-color: #9C27B0; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Accedi">
                            <font>
                                <Font name="Segoe UI Bold" size="12.0" />
                            </font>
                            <VBox.margin>
                                <Insets left="24.0" right="24.0" top="20.0" />
                            </VBox.margin>
                        </Button>

                        <Label fx:id="lblMessaggioLogin" alignment="CENTER" maxWidth="302.0" textFill="#D32F2F" wrapText="true">
                            <font>
                                <Font name="Segoe UI Bold" size="11.5" />
                            </font>
                            <VBox.margin>
                                <Insets left="24.0" right="24.0" top="8.0" />
                            </VBox.margin>
                        </Label>

                        <Button mnemonicParsing="false" onAction="#onTornaHomeClick" style="-fx-background-color: transparent; -fx-text-fill: #9C27B0; -fx-cursor: hand;" text="Torna alla Home" underline="true">
