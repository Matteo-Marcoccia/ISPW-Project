                                </Label>
                                <Button mnemonicParsing="false" onAction="#onPrenotaOraClick" prefHeight="36.0" prefWidth="262.0" style="-fx-background-color: #9C27B0; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Prenota Ora">
