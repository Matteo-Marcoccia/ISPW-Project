                                    <VBox.margin>
                                        <Insets left="24.0" top="8.0" />
                                    </VBox.margin>
                                </Label>
                                <Button mnemonicParsing="false" onAction="#onVaiAlloShopClick" prefHeight="36.0" prefWidth="262.0" style="-fx-background-color: #1976D2; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Vai allo Shop">
