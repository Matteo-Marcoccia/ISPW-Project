            <Button fx:id="btnAccedi" mnemonicParsing="false" onAction="#onAccediClick" style="-fx-background-color: rgba(255, 255, 255, 0.20); -fx-text-fill: white; -fx-background-radius: 20; -fx-border-color: rgba(255, 255, 255, 0.42); -fx-border-radius: 20; -fx-border-width: 1; -fx-padding: 7 18 7 18; -fx-cursor: hand;" text="Accedi">
