                                    <VBox.margin>
                                        <Insets left="24.0" top="25.0" />
                                    </VBox.margin>
                                </Button>
                            </children>
                        </VBox>

                        <VBox fx:id="boxShop" prefHeight="260.0" prefWidth="310.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 10, 0, 0, 4);">
