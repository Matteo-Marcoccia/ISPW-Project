                                    </VBox.margin>
                                </Label>
                                <Button mnemonicParsing="false" onAction="#onConfermaPrenotazioniClick" prefHeight="36.0" prefWidth="262.0" style="-fx-background-color: #B24A3B; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Conferma Prenotazioni">
