                                <StackPane alignment="CENTER" maxHeight="46.0" maxWidth="46.0" prefHeight="46.0" prefWidth="46.0">
                                    <children>
                                        <Rectangle arcHeight="14.0" arcWidth="14.0" fill="#1976D2" height="44.0" width="44.0" />
                                        <SVGPath content="M12 2C10.34 2 9 3.34 9 5H4v14c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V5h-5c0-1.66-1.34-3-3-3zm0 2c.55 0 1 .45 1 1h-2c0-.55.45-1 1-1zm6 15H6V7h12v12z" fill="WHITE" scaleX="0.9" scaleY="0.9" />
                                    </children>
                                    <VBox.margin>
                                        <Insets left="24.0" top="24.0" />
                                    </VBox.margin>
                                </StackPane>

                                <Label text="Acquista Giochi" textFill="#1A1A1A">
                                    <font>
                                        <Font name="System Bold" size="20.0" />
