                            <children>
                                <StackPane alignment="CENTER" maxHeight="46.0" maxWidth="46.0" prefHeight="46.0" prefWidth="46.0">
                                    <children>
                                        <Rectangle arcHeight="14.0" arcWidth="14.0" fill="#B24A3B" height="44.0" width="44.0" />
                                        <SVGPath content="M9 16.2l-3.5-3.5L4 14.2 9 19l11-11-1.5-1.5z" fill="WHITE" scaleX="0.9" scaleY="0.9" />
                                    </children>
                                    <VBox.margin>
                                        <Insets left="24.0" top="24.0" />
                                    </VBox.margin>
                                </StackPane>

                                <Label text="Prenotazioni in Attesa" textFill="#1A1A1A">
                                    <font>
                                        <Font name="System Bold" size="20.0" />
