                        <Label text="Benvenuto nel nostro Spazio Giochi" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="8.0" />
                            </VBox.margin>
                        </Label>
                        <Label alignment="CENTER" prefWidth="580.0" text="QuestTable e' il luogo perfetto per gli appassionati di giochi da tavolo. Prenota un tavolo per giocare con i tuoi amici nella nostra sala dedicata, oppure acquista giochi dalla nostra selezione curata per portarli a casa" textAlignment="CENTER" textFill="#EAEAEA" wrapText="true">
