                                <Font size="12.0" />
                            </font>
                        </Label>
                        <Button fx:id="btnStoricoPrenotazioni" managed="false" mnemonicParsing="false" onAction="#onStoricoPrenotazioniClick" style="-fx-background-color: #009688; -fx-text-fill: white; -fx-background-radius: 18; -fx-padding: 7 18 7 18; -fx-cursor: hand;" text="Storico Prenotazioni" visible="false">
                            <font>
                                <Font name="System Bold" size="12.0" />
