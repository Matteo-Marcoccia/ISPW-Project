                                <StackPane alignment="CENTER" maxHeight="46.0" maxWidth="46.0" prefHeight="46.0" prefWidth="46.0">
                                    <children>
                                        <Rectangle arcHeight="14.0" arcWidth="14.0" fill="#9C27B0" height="44.0" width="44.0" />
                                        <SVGPath content="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z" fill="WHITE" scaleX="0.9" scaleY="0.9" />
