<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: linear-gradient(to bottom right, #6200EE, #E61C5D);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.questtable.view.javafx.controller.DettagliTavoloController">
    <children>
        <HBox alignment="CENTER_LEFT" layoutX="30.0" layoutY="20.0" prefHeight="45.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="20.0">
            <children>
                <Button mnemonicParsing="false" onAction="#onTornaListaClick" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="&lt; Torna ai Tavoli">
                    <font>
                        <Font name="Segoe UI Bold" size="13.0" />
                    </font>
                </Button>
            </children>
        </HBox>

        <VBox alignment="CENTER" spacing="18.0" AnchorPane.bottomAnchor="24.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="64.0">
            <children>
                <VBox alignment="CENTER" spacing="6.0">
                    <children>
                        <Label text="Dettagli Tavolo" textFill="WHITE">
                            <font>
                                <Font name="Segoe UI Bold" size="30.0" />
                            </font>
                        </Label>
                        <Label text="Scegli quanti posti vuoi prenotare al tavolo" textFill="#EAEAEA">
                            <font>
                                <Font name="Segoe UI" size="13.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox alignment="TOP_CENTER" maxWidth="430.0" prefWidth="430.0" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 10, 0, 0, 4);">
                    <padding>
                        <Insets bottom="18.0" left="24.0" right="24.0" top="18.0" />
                    </padding>
                    <children>
                        <ImageView fx:id="imgGioco" fitHeight="90.0" fitWidth="160.0" preserveRatio="true" smooth="true" />

                        <VBox alignment="CENTER_LEFT" spacing="6.0">
                            <children>
                                <Label text="Tavolo" textFill="#1A1A1A">
                                    <font>
                                        <Font name="Segoe UI Bold" size="13.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblNomeTavoloStatico" text="Tavolo selezionato" textFill="#666666">
                                    <font>
                                        <Font name="Segoe UI" size="13.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <HBox spacing="14.0">
                            <children>
                                <VBox alignment="CENTER_LEFT" spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Giorno" textFill="#1A1A1A">
                                            <font>
                                                <Font name="Segoe UI Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="lblGiornoStatico" maxWidth="180.0" prefHeight="35.0" style="-fx-background-color: #F4F4F6; -fx-background-radius: 6; -fx-padding: 9 10 9 10; -fx-text-fill: #1A1A1A;" text="Giorno">
                                            <font>
                                                <Font name="Segoe UI" size="12.5" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER_LEFT" spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Fascia oraria" textFill="#1A1A1A">
                                            <font>
                                                <Font name="Segoe UI Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="lblFasciaOrariaStatica" maxWidth="180.0" prefHeight="35.0" style="-fx-background-color: #F4F4F6; -fx-background-radius: 6; -fx-padding: 9 10 9 10; -fx-text-fill: #1A1A1A;" text="Ora">
                                            <font>
                                                <Font name="Segoe UI" size="12.5" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label text="Numero partecipanti" textFill="#1A1A1A">
                                    <font>
                                        <Font name="Segoe UI Bold" size="13.0" />
                                    </font>
                                </Label>
                                <HBox alignment="CENTER" spacing="18.0">
                                    <children>
                                        <Button fx:id="btnDiminuisciPartecipanti" mnemonicParsing="false" onAction="#onDiminuisciPartecipantiClick" prefHeight="34.0" prefWidth="34.0" style="-fx-background-color: #F4F4F6; -fx-text-fill: #6200EE; -fx-background-radius: 17; -fx-cursor: hand;" text="-">
                                            <font>
                                                <Font name="Segoe UI Bold" size="18.0" />
                                            </font>
                                        </Button>
                                        <Label fx:id="lblNumeroPartecipanti" alignment="CENTER" prefHeight="52.0" prefWidth="52.0" style="-fx-background-color: #6200EE; -fx-background-radius: 26; -fx-text-fill: white;" text="1">
                                            <font>
                                                <Font name="Segoe UI Bold" size="20.0" />
                                            </font>
                                        </Label>
                                        <Button fx:id="btnAumentaPartecipanti" mnemonicParsing="false" onAction="#onAumentaPartecipantiClick" prefHeight="34.0" prefWidth="34.0" style="-fx-background-color: #F4F4F6; -fx-text-fill: #6200EE; -fx-background-radius: 17; -fx-cursor: hand;" text="+">
                                            <font>
                                                <Font name="Segoe UI Bold" size="18.0" />
                                            </font>
                                        </Button>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox prefHeight="148.0" spacing="3.0" style="-fx-background-color: #F7F5FC; -fx-background-radius: 12;">
                            <padding>
                                <Insets bottom="12.0" left="16.0" right="16.0" top="12.0" />
                            </padding>
                            <children>
                                <Label text="Riepilogo" textFill="#6200EE">
                                    <font>
                                        <Font name="Segoe UI Bold" size="14.0" />
                                    </font>
                                </Label>
                                <HBox alignment="CENTER_LEFT" prefHeight="22.0">
                                    <children>
                                        <Label text="Tavolo" textFill="#666666" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblRiepilogoTavolo" text="-" textFill="#1A1A1A">
                                            <font>
                                                <Font name="Segoe UI Bold" size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" prefHeight="22.0">
                                    <children>
                                        <Label text="Partecipanti" textFill="#666666" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblRiepilogoPartecipanti" text="1" textFill="#1A1A1A">
                                            <font>
                                                <Font name="Segoe UI Bold" size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" prefHeight="22.0">
                                    <children>
                                        <Label text="Quota" textFill="#666666" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblRiepilogoPrezzoUnitario" text="-" textFill="#1A1A1A">
                                            <font>
                                                <Font name="Segoe UI Bold" size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" prefHeight="22.0">
                                    <children>
                                        <Label text="Punti fedelta" textFill="#4CAF50" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblRiepilogoPuntiFedelta" text="+0 punti" textFill="#4CAF50">
                                            <font>
                                                <Font name="Segoe UI Bold" size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" prefHeight="30.0">
                                    <children>
                                        <Label text="Costo stimato:" textFill="#1A1A1A">
                                            <font>
                                                <Font name="Segoe UI Bold" size="15.0" />
                                            </font>
                                        </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblRiepilogoCostoTotale" text="-" textFill="#6200EE">
                                            <font>
                                                <Font name="Segoe UI Bold" size="16.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <Button mnemonicParsing="false" onAction="#onConfermaPrenotazioneClick" prefHeight="38.0" maxWidth="Infinity" style="-fx-background-color: #6200EE; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Calcola preventivo">
                            <font>
                                <Font name="Segoe UI Bold" size="12.5" />
                            </font>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
